  "keyFeatures": [
    "Multi-tenant architecture with role-based access control",
    "Obra (construction project) lifecycle management",
    "Centralized document storage and organization per project",
    "AI-powered OCR and automatic data extraction from documents",
    "Certificate management and generation with PDF rendering",
    "Budget tracking, financial deviation detection, and reporting",
    "Workflow automation with configurable flujo actions",
    "Real-time notifications via in-app and WhatsApp",
    "Macro tables for cross-project data aggregation",
    "Subscription plans with per-tenant usage enforcement"
